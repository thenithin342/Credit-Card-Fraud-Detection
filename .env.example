# environment variables — copy this to .env and fill in your values
# NEVER commit .env to git

# ── Kaggle API Credentials ────────────────────────────────────────
# NEW format (Kaggle tokens starting with KGAT_) — use this if you
# generated your token from kaggle.com after mid-2024:
KAGGLE_API_TOKEN=KGAT_your_token_here

# OLD format (classic username + key) — use this if your token is
# a 32-char hex string without the KGAT_ prefix:
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ── MLflow ────────────────────────────────────────────────────────────────────────
# Local file store (default for dev / CI — no auth required):
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_ALLOW_FILE_STORE=true

# Remote DagsHub MLflow (Production). To enable:
#   1. Sign in to https://dagshub.com, open your repo.
#   2. Settings → Tokens → Generate a new access token.
#   3. Paste the token below, then uncomment the four DagsHub lines.
#   4. The training/serving code picks this up via os.environ — no
#      other config change needed.
MLFLOW_TRACKING_URI=https://dagshub.com/thenithin342/Credit-Card-Fraud-Detection.mlflow
MLFLOW_TRACKING_USERNAME=thenithin342
MLFLOW_TRACKING_PASSWORD=your_dagshub_token
MLFLOW_EXPERIMENT_NAME=fraudguard-experiments

# ── Redis (online feature store) ─────────────────────────────────
USE_FAKEREDIS=True
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Postgres (prediction logs) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraudguard
POSTGRES_USER=fraudguard
POSTGRES_PASSWORD=changeme

# ── Serving ──────────────────────────────────────────────────────
API_KEY=change-me-before-deploying
LOG_LEVEL=INFO

# ── Redpanda / Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions.raw
KAFKA_TOPIC_PREDICTIONS=prediction-logs
