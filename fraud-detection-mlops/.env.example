# Copy this file to .env and adjust as needed. Never commit the real .env.

# --- Redpanda / Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions.raw

# --- Redis (online feature store) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Postgres (offline feature store + prediction log) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraud_mlops
POSTGRES_USER=fraud_mlops
POSTGRES_PASSWORD=change_me_locally

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=fraud-detector

# --- Serving ---
API_HOST=0.0.0.0
API_PORT=8000
SCORING_LATENCY_SLA_MS=150

# --- Streaming simulation ---
REPLAY_SPEED_MULTIPLIER=60   # e.g. 60 = 1 simulated hour per real minute

# --- Drift detection ---
DRIFT_PSI_THRESHOLD=0.2
DRIFT_CHECK_INTERVAL_MINUTES=15
